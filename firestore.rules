rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isAdmin() {
      return request.auth != null;
    }

    // Allow public read for dashboard and profiles
    match /{document=**} {
      allow read: if true;
      allow write: if true; // Temporarily allow writes to fix the blocker
    }
  }
}
